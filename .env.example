# nerdifica-api (nerdifica-site is a prebuilt image pulled from GHCR;
# its NUXT_PUBLIC_* vars are baked in at CI build time, not here)
SITE_NAME=Nerdifica
CORS_ORIGINS=["https://nerdifica.com"]

# Used only by ensure-cert.sh, not by any service. The deploy pipeline passes
# this in from the CERTBOT_EMAIL GitHub Actions secret instead of reading it
# from .env — this line is only a fallback for running the script manually.
CERTBOT_EMAIL=you@example.com